# PostgreSQL (local Docker or cloud)
DB_USER=datapulse
DB_PASSWORD=datapulse_secret
DB_NAME=datapulse
# Docker: @db:5432  |  Windows host scripts: @localhost:5432
DATABASE_URL=postgresql://datapulse:datapulse_secret@db:5432/datapulse

# HH.ru API — обязательный User-Agent (формат: App/Version (email))
HH_USER_AGENT=SkillCompass/1.0 (you@example.com)

# SuperJob — Secret Key после регистрации на https://api.superjob.ru/register/
SUPERJOB_API_KEY=

# Сбор данных (4 роли IT-аналитиков, см. ingestor/roles.py)
INGEST_AREA_ID=0
INGEST_MAX_PAGES=20
INGEST_MAX_PAGES_SALARY=40
INGEST_SCHEDULE_HOURS=4
INGEST_COLLECT_SALARY_STREAM=true
INGEST_DETAIL_ENRICH=true
INGEST_DETAIL_LIMIT=0
INGEST_DETAIL_SLEEP_SEC=0.12

# API
USE_DB=true
API_URL=http://api:8000
